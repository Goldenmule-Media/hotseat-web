# wiki-ui configuration. Copy to `.env.local` and adjust to point at your wiki-server.
# These are NEXT_PUBLIC_* because the engine runs in the browser (client-side).

# Durable Streams base URL of the wiki-server (the stream host, default port 4437).
# Auth needs no UI-side configuration: if this server's GitHub-auth gateway is enabled
# (GET {base}/auth/config -> {"enabled":true}), the UI gates behind "Sign in with GitHub"
# and keeps the bearer token in localStorage — no secrets live in this app. When auth is
# disabled the app behaves exactly as before.
NEXT_PUBLIC_WIKI_STREAM_BASE_URL=http://127.0.0.1:4437

# Stream namespace — must match the server's WIKI_MCP_NAMESPACE (default: "default").
NEXT_PUBLIC_WIKI_NAMESPACE=default

# MCP endpoint shown in the splash page's "Quick start" install command. Defaults to
# `{NEXT_PUBLIC_WIKI_STREAM_BASE_URL}/mcp` (correct on the deployed server, where the gateway
# proxies /mcp on the same origin). Override for local dev, where MCP listens on its own port:
# NEXT_PUBLIC_WIKI_MCP_URL=http://127.0.0.1:4439/mcp

# Local wiki-mirror health endpoint, polled to show a "Mirror" status indicator. This is
# ALWAYS a localhost URL, independent of the (possibly remote) stream base URL above — the
# wiki-mirror process runs on YOUR machine, mirroring the workspace to a local checkout.
# Default port 4440 (4437 stream / 4438 control / 4439 mcp / 4440 mirror). Note: when this app
# is served over https the browser blocks fetching this http URL (mixed content) and the
# indicator hides itself.
# NEXT_PUBLIC_WIKI_MIRROR_HEALTH_URL=http://127.0.0.1:4440
