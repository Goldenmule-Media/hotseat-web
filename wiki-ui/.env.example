# wiki-ui configuration. Copy to `.env.local` and adjust to point at your wiki-server.
# These are NEXT_PUBLIC_* because the engine runs in the browser (client-side).

# Durable Streams base URL of the wiki-server (the stream host, default port 4437).
NEXT_PUBLIC_WIKI_STREAM_BASE_URL=http://127.0.0.1:4437

# Stream namespace — must match the server's WIKI_MCP_NAMESPACE (default: "default").
NEXT_PUBLIC_WIKI_NAMESPACE=default
