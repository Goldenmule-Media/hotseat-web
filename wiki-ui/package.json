{
  "name": "wiki-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only, live-updating browser for a wiki-server. Embeds the wiki engine in the browser and tails the Durable Stream directly.",
  "type": "module",
  "scripts": {
    "copy-pglite-assets": "node ./scripts/copy-pglite-assets.mjs",
    "write-build-info": "node ./scripts/write-build-info.mjs",
    "predev": "npm run copy-pglite-assets",
    "dev": "next dev",
    "prebuild": "npm run copy-pglite-assets && npm run write-build-info",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@xyflow/react": "^12.11.0",
    "comlink": "^4.4.2",
    "dagre": "^0.8.5",
    "kysely": "^0.27.5",
    "marked": "^14.1.4",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wiki": "file:../wiki",
    "wiki-models": "file:../wiki-models"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.54",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "wiki": "file:../wiki"
  }
}
