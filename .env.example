# wiki-server config — copy to .env. Also drives the docker-compose deploy (see DEPLOY.md).

# Deployment (docker-compose).
POSTGRES_PASSWORD=<a strong random password>   # e.g. openssl rand -base64 24
WIKI_DOMAIN=<your.domain.com>                  # Caddy TLS host; matches WIKI_SERVER_PUBLIC_URL sans scheme

# Auth is OFF by default; everything below applies to --auth github.
#
# Create a GitHub OAuth App (Settings → Developer settings → OAuth Apps → New):
#   Homepage URL:               http://localhost:3000
#   Authorization callback URL: ${WIKI_SERVER_PUBLIC_URL}/auth/github/callback
#                               (e.g. http://127.0.0.1:4437/auth/github/callback)

WIKI_SERVER_AUTH=github
WIKI_SERVER_GITHUB_CLIENT_ID=<your OAuth app client id>
WIKI_SERVER_GITHUB_CLIENT_SECRET=<your OAuth app client secret>

# The gateway's EXTERNAL base URL — what browsers and GitHub's callback reach it at.
# Behind DNS/TLS set the https URL; the OAuth app callback must match it exactly.
WIKI_SERVER_PUBLIC_URL=http://127.0.0.1:4437

# Origins allowed as post-login redirect targets (where wiki-ui runs).
WIKI_SERVER_UI_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# STRONGLY RECOMMENDED: GitHub logins allowed to sign in (comma-separated,
# case-insensitive). Unset = ANY GitHub account can establish a session —
# workspace membership still gates content, but the workspace index and any
# unclaimed (pre-auth) workspace are open to every signed-in user.
WIKI_SERVER_AUTH_USERS=<your-github-login>,<teammate-login>

# Optional. HMAC secret for session tokens (e.g. `openssl rand -hex 32`). When unset,
# one is generated and persisted at <dataDir>/auth/session-secret. Rotating it signs
# every user out (the revocation story for stateless sessions).
#WIKI_SERVER_SESSION_SECRET=

# Optional. Session lifetime in days (default 30) — the interactive (wiki-ui) flow's tokens.
#WIKI_SERVER_SESSION_TTL_DAYS=30

# Optional. OAuth-minted access-token lifetime in seconds (default 3600) and
# refresh-token lifetime in days (default = WIKI_SERVER_SESSION_TTL_DAYS).
# These govern the OAuth 2.1 login flow (MCP clients + `wiki-mirror login`),
# not the interactive session above.
#WIKI_SERVER_ACCESS_TOKEN_TTL_SECONDS=3600
#WIKI_SERVER_REFRESH_TOKEN_TTL_DAYS=30

# Clients sign in via OAuth — no token copying:
#  - the wiki MCP server in .mcp.json needs NO Authorization header: on the first
#    401, an MCP client (e.g. Claude Code: /mcp -> Authenticate) discovers the
#    OAuth flow, opens the browser, and manages + refreshes its tokens itself;
#  - CLIs: `wiki-mirror login --stream-url <url>` stores a refreshing grant in
#    ~/.wiki/credentials.json, shared by wiki-mirror and migrate-workspace.
# A manually copied token (wiki-ui account menu) still works and takes precedence:
#  - .mcp.json: "headers": { "Authorization": "Bearer <token>" }
#  - wiki-mirror: WIKI_MIRROR_TOKEN=<token>
