{
  "name": "wiki-server",
  "version": "0.1.0",
  "type": "module",
  "description": "Durable Streams host for the wiki engine — runs @durable-streams/server with durable storage AND hosts wiki-mcp in-process. Imports @durable-streams/server and wiki-mcp, never `wiki` directly.",
  "bin": {
    "wiki-server": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx src/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@durable-streams/server": "^0.3.5",
    "wiki-mcp": "*"
  },
  "devDependencies": {
    "@durable-streams/client": "^0.2.6"
  }
}
