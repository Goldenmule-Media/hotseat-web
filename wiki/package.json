{
  "name": "wiki",
  "version": "0.1.0",
  "type": "module",
  "description": "A TypeScript-only, embeddable, event-sourced structured wiki engine.",
  "exports": {
    ".": "./src/index.ts",
    "./pages/feature": "./src/pages/feature/index.ts",
    "./testing": "./src/testing.ts"
  },
