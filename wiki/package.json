{
  "name": "wiki",
  "version": "0.1.0",
  "type": "module",
  "description": "A TypeScript-only, embeddable, event-sourced structured wiki engine.",
  "exports": {
    ".": "./src/index.ts",
    "./admin": "./src/admin.ts",
    "./auth-client": "./src/auth-client.ts",
    "./authoring": "./src/authoring.ts",
    "./testing": "./src/testing.ts",
    "./registry": "./src/core/registry.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@durable-streams/client": "^0.2.6",
    "kysely": "^0.27.5",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@durable-streams/server": "^0.3.5",
    "@electric-sql/pglite": "^0.2.17",
    "wiki-models": "*"
  }
}
